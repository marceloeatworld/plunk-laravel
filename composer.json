{
    "name": "marceloeatworld/plunk-laravel",
    "description": "Laravel mail transport for Plunk API with event tracking and email verification",
    "keywords": ["laravel", "plunk", "mail", "email", "transport", "transactional"],
    "license": "MIT",
    "authors": [
        {
            "name": "marcelo",
            "email": "diagngo@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/mail": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "MarceloEatWorld\\PlunkLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MarceloEatWorld\\PlunkLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MarceloEatWorld\\PlunkLaravel\\PlunkServiceProvider"
            ],
            "aliases": {
                "Plunk": "MarceloEatWorld\\PlunkLaravel\\Facades\\Plunk"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
